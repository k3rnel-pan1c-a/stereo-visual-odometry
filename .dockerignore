# Keep the build context small and the image clean.

# Build artifacts
build/
**/build/
*.o
*.obj

# Outputs (mounted at runtime instead)
outputs/
**/outputs/

# Datasets (mounted at runtime, never bake into image)
dataset/
data/
**/sequences/
**/poses/
*.svo
*.svo2
*.bin
*.ply

# Editor / IDE state
.vscode/
.idea/
*.swp
*.swo

# VCS
.git/
.gitignore
.gitattributes

# Helper script doesn't need to live inside the image
docker-run.sh

# Compiled documents (LaTeX) — these shouldn't be at monoslam/ but just in case
*.pdf
*.aux
*.log
*.toc
*.out
*.synctex.gz
